generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @map("_id")
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  role          UserRole?
  accounts      Account[]
  artists       Artist[]
  Media         Media[]
  sessions      Session[]
  venues        Venue[]

  @@map("user")
}

model Session {
  id        String   @id @map("_id")
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @map("_id")
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @map("_id")
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Artist {
  id               String   @id @default(cuid()) @map("_id")
  userId           String
  stageName        String
  photoUrl         String?
  bannerUrl        String?
  bio              String?
  website          String?
  socialLinks      Json?    @default("{}")
  images           String[] @default([])
  techRequirements String?
  feeMin           Int?
  feeMax           Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  city             String?
  isNegotiable     Boolean  @default(false)
  postalCode       String?
  latitude         Float?
  longitude        Float?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  genres           Genre[]  @relation("ArtistToGenre")
  media            Media[]  @relation("ArtistToMedia")

  @@map("artist")
}

model Venue {
  id            String        @id @default(cuid()) @map("_id")
  name          String
  address       String
  city          String
  postalCode    String
  country       String        @default("France")
  venueType     VenueType
  capacity      Int?
  description   String?
  photoUrl      String?
  logoUrl       String?
  images        String[]      @default([])
  paymentPolicy String?
  techInfo      String?
  ownerId       String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  budgetMax     Int?
  budgetMin     Int?
  paymentTypes  PaymentType[] @default([])
  latitude      Float?
  longitude     Float?
  owner         User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  genres        Genre[]       @relation("GenreToVenue")

  @@map("venue")
}

model Genre {
  id      String   @id @default(cuid()) @map("_id")
  name    String   @unique
  artists Artist[] @relation("ArtistToGenre")
  venues  Venue[]  @relation("GenreToVenue")

  @@map("genre")
}

model Media {
  id          String   @id @default(cuid()) @map("_id")
  name        String
  description String?
  website     String?
  logoUrl     String?
  country     String?  @default("France")
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  artist      Artist[] @relation("ArtistToMedia")

  @@map("media")
}

model Conversation {
  id           String                    @id @default(cuid()) @map("_id")
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversation")
}

model ConversationParticipant {
  id             String       @id @default(cuid()) @map("_id")
  conversationId String
  entityId       String
  entityType     EntityType
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, entityId, entityType])
  @@map("conversation_participant")
}

model Message {
  id             String       @id @default(cuid()) @map("_id")
  content        String
  createdAt      DateTime     @default(now())
  conversationId String
  senderId       String
  senderType     EntityType
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("message")
}

enum VenueType {
  BAR
  CLUB
  CONCERT_HALL
  FESTIVAL
  CAFE
  RESTAURANT
  CULTURAL_CENTER
  THEATER
  OPEN_AIR
  OTHER
}

enum UserRole {
  ARTIST
  ORGANIZER
  MEDIA
  TECH_SERVICE
  BOTH
}

enum PaymentType {
  FIXED_FEE
  PERCENTAGE
  HAT
  NEGOTIABLE
}

enum EntityType {
  ARTIST
  VENUE
  MEDIA
}
